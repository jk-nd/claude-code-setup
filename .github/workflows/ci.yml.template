# =====================================================================
# GO-SPECIFIC REFERENCE PIPELINE
# ---------------------------------------------------------------------
# The build / vet / test / lint steps below assume a Go project. If your
# project is NOT Go, replace the per-language `run:` lines (and the
# `setup-go` / golangci-lint steps) with your stack's equivalents —
# e.g. pytest + ruff for Python, `opa test` for Rego. The job-shape
# (paths-filter → gated jobs → fail-closed `ci-pass` aggregator, with
# cache + concurrency cancellation) carries over to any stack unchanged;
# only the language steps differ. `bootstrap.sh` activates this file as
# `ci.yml` only for Go projects; for other stacks it is left as a
# clearly-marked reference for you to adapt.
# =====================================================================

name: CI

on:
  # No workflow-level `paths-ignore`: the `ci-pass` aggregator below is
  # the single required status check, and a required check that is
  # skipped by path filtering stays "pending" forever, blocking the PR.
  # Doc-only / metadata-only PRs are handled instead at the job level —
  # the `paths` job detects no Go changes, the Go jobs skip, and
  # `ci-pass` still runs and passes. Same Actions-minutes saving, no
  # merge deadlock.
  pull_request:
    branches: [main]
  push:
    branches: [main]
  # GitHub merge queue — re-runs build/test/lint against the queued PR
  # rebased onto post-previous-merge `main` before letting the merge land.
  # Eliminates the merge-cascade collision pattern where two PRs that pass
  # CI individually break `main` when both land sequentially. See
  # `docs/operating.md` for the explainer and AGENTS.md operating
  # clarification on merge-cascade collisions. Bootstrap optionally
  # enables the merge queue via `gh api graphql` on the repo's branch
  # protection ruleset; this trigger is harmless when the queue is off.
  merge_group:
    types: [checks_requested]

permissions:
  contents: read
  pull-requests: read

# Cancel an in-flight run on the same ref when a fresh push lands.
# Saves CI minutes during agent-driven workflows where many pushes
# arrive in rapid succession on the same branch.
concurrency:
  group: ci-${{ github.workflow }}-${{ github.ref }}
  cancel-in-progress: true

jobs:
  # Per-job paths filter (OPTIONAL — see comment block below).
  #
  # Lifted from the go-mcp-gw reference repo. The default jobs in this
  # template (build-and-test, lint, actionlint) do not need filtering —
  # they are cheap enough to run unconditionally. The `paths` job is
  # provided so project-specific jobs added later (e2e, examples,
  # fuzz, oscal-check, translator-roundtrip, etc.) can opt in by
  # consuming `needs.paths.outputs.<filter-name>` in a job-level `if:`.
  #
  # Cost model: this job runs `dorny/paths-filter@d1c1ffe0248fe513906c8e24db8ea791d46f8590 # v3` once per PR push.
  # Single ubuntu-latest, only checkout + the filter action — no Go,
  # no build. The cost added here is paid back many-fold once even one
  # downstream job is gated on it.
  #
  # `workflows` is a project-agnostic filter that downstream jobs can
  # use; the only sample downstream consumer in this template is the
  # `actionlint` job, which gates on `.github/workflows/**` changes.
  # Add additional filters here as your project grows (per-area Go
  # paths, e2e paths, examples, etc.).
  paths:
    runs-on: ubuntu-latest
    outputs:
      go: ${{ steps.f.outputs.go }}
      workflows: ${{ steps.f.outputs.workflows }}
    steps:
      - uses: actions/checkout@34e114876b0b11c390a56381ad16ebd13914f8d5 # v4
      - uses: dorny/paths-filter@d1c1ffe0248fe513906c8e24db8ea791d46f8590 # v3
        id: f
        with:
          filters: |
            go:
              - '**/*.go'
              - '**/go.mod'
              - '**/go.sum'
            workflows:
              - '.github/workflows/**'

  build-and-test:
    runs-on: ubuntu-latest
    needs: paths
    if: needs.paths.outputs.go == 'true'
    steps:
      - uses: actions/checkout@34e114876b0b11c390a56381ad16ebd13914f8d5 # v4

      - name: Set up Go
        uses: actions/setup-go@40f1582b2485089dde7abd97c1529aa768e1baff # v5
        with:
          go-version: '1.26'
          cache: true

      - name: Verify go.mod tidy
        run: |
          go mod tidy
          git diff --exit-code -- go.mod go.sum

      - name: Build
        run: go build ./...

      - name: Vet
        run: go vet ./...

      - name: Test
        run: go test -race -count=1 -timeout=5m ./...

  lint:
    runs-on: ubuntu-latest
    needs: paths
    if: needs.paths.outputs.go == 'true'
    steps:
      - uses: actions/checkout@34e114876b0b11c390a56381ad16ebd13914f8d5 # v4

      - name: Set up Go
        uses: actions/setup-go@40f1582b2485089dde7abd97c1529aa768e1baff # v5
        with:
          go-version: '1.26'
          cache: true

      - uses: golangci/golangci-lint-action@9fae48acfc02a90574d7c304a1758ef9895495fa # v7
        with:
          version: v2.11.4
          args: --timeout=5m

  # actionlint — workflow YAML linter.
  #
  # Catches the `matrix.filter` class of bug pre-merge instead of via a
  # phantom 0-job CI run. This is the gap that broke go-mcp-gw CI for
  # ~6 hours when a workflow PR used `matrix.<key>` in a job-level `if:`
  # — actionlint flags this immediately because the matrix context is
  # not in scope for `jobs.<id>.if`, only `github`, `inputs`, `needs`,
  # and `vars`.
  #
  # Gated on the `workflows` filter so this job runs only when
  # `.github/workflows/**` actually changed.
  actionlint:
    runs-on: ubuntu-latest
    needs: paths
    if: needs.paths.outputs.workflows == 'true'
    steps:
      - uses: actions/checkout@34e114876b0b11c390a56381ad16ebd13914f8d5 # v4
      - name: Run actionlint
        env:
          ACTIONLINT_VERSION: 1.7.7
        run: |
          # Supply-chain policy (see SECURITY.md): no `curl | bash` of a
          # remote script. Download the pinned release artifact and verify
          # it against the release's published checksums before running.
          base="https://github.com/rhysd/actionlint/releases/download/v${ACTIONLINT_VERSION}"
          tarball="actionlint_${ACTIONLINT_VERSION}_linux_amd64.tar.gz"
          # Keep the release filename on disk: `sha256sum -c` verifies by the
          # filename listed in the checksums file, so the downloaded file must
          # carry that exact name.
          curl -sSfL -o "$tarball" "${base}/${tarball}"
          curl -sSfL -o actionlint_checksums.txt "${base}/actionlint_${ACTIONLINT_VERSION}_checksums.txt"
          grep " ${tarball}$" actionlint_checksums.txt | sha256sum -c -
          tar -xzf "$tarball" actionlint
          ./actionlint -color

  # Aggregator job — the single overall CI signal.
  #
  # Make THIS the required status check in branch protection (bootstrap.sh
  # configures it), not the individual jobs: the Go jobs are path-gated
  # and skip on non-Go PRs, and a skipped *required* check blocks the PR.
  #
  # FAIL-CLOSED on two fronts:
  #   - the `paths` filter MUST have succeeded. If it failed, the gated
  #     jobs skip on a false "nothing relevant changed" reading, and the
  #     aggregate would otherwise pass green with the suite silently
  #     disabled. So a non-success `paths` result is a hard failure.
  #   - any gated job that failed or was cancelled fails the aggregate.
  # A gated job that was *skipped* is OK — its paths were not touched, so
  # it was legitimately not run. `if: always()` ensures this job always
  # runs and always reports a result.
  #
  # Adding a new gated job: add it to `needs:` and to the loop below.
  ci-pass:
    runs-on: ubuntu-latest
    needs: [paths, build-and-test, lint, actionlint]
    if: always()
    steps:
      - name: Aggregate
        run: |
          # The paths filter is load-bearing for every skip decision
          # below; if it did not succeed, the gating is untrustworthy.
          echo "  paths: ${{ needs.paths.result }}"
          if [ "${{ needs.paths.result }}" != "success" ]; then
            echo "ci-pass: FAILED — the paths filter job did not succeed; gating is unreliable."
            exit 1
          fi
          failed=0
          for job in build-and-test lint actionlint; do
            case "$job" in
              build-and-test) r="${{ needs.build-and-test.result }}" ;;
              lint)           r="${{ needs.lint.result }}" ;;
              actionlint)     r="${{ needs.actionlint.result }}" ;;
            esac
            echo "  $job: $r"
            if [ "$r" = "failure" ] || [ "$r" = "cancelled" ]; then
              failed=1
            fi
          done
          if [ "$failed" -eq 1 ]; then
            echo "ci-pass: FAILED — a gated job failed or was cancelled."
            exit 1
          fi
          echo "ci-pass: OK (paths succeeded; all gated jobs passed or were skipped)."

  # ---------------------------------------------------------------------
  # OPTIONAL example: paths-gated job (commented out)
  # ---------------------------------------------------------------------
  #
  # The pattern below shows how to add a project-specific job that runs
  # only when its inputs change. Uncomment + adapt for your project's
  # e2e, fuzz, examples, or translator-roundtrip suites.
  #
  # First, add a filter to the `paths` job above (e.g. `e2e:` with the
  # path globs your e2e tests transitively depend on). Then declare the
  # downstream job with `needs: [build-and-test, paths]` and gate it on
  # the filter output in a job-level `if:`.
  #
  # e2e:
  #   runs-on: ubuntu-latest
  #   needs: [build-and-test, paths]
  #   if: needs.paths.outputs.e2e == 'true'
