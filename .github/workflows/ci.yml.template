  #       uses: actions/setup-go@40f1582b2485089dde7abd97c1529aa768e1baff # v5
  #       with:
  #         go-version: '1.26'
  #         cache: true
  #     - name: E2E tests
  #       run: go test -tags e2e -race -count=1 -timeout=5m ./test/e2e/...
