name: Weekly docs audit

# Opens a single issue per audit cycle. The orchestrator picks it up,
# dispatches `doc-keeper` in audit mode against `main`, and files
# additional `doc-stale` issues for drift found.
#
# The audit issue's existence is the signal — no LLM runs in CI.
#
# Trigger:
#   - schedule: Monday 09:00 UTC.
#   - workflow_dispatch: manual run.

on:
  schedule:
    - cron: '0 9 * * 1'
  workflow_dispatch: {}

permissions:
  contents: read
  issues: write

jobs:
  open-audit-issue:
    runs-on: ubuntu-latest
    steps:
      - name: Open audit issue
        uses: actions/github-script@v7
        with:
          script: |
            const owner = context.repo.owner;
            const repo  = context.repo.repo;
            const today = new Date().toISOString().split('T')[0];
            const title = `Weekly docs audit due — ${today}`;
            const body = [
              'Automatic weekly docs audit.',
              '',
              'The `doc-keeper` subagent should run in audit mode against',
              '`main`, walk the repo, and open additional `doc-stale` issues',
              'for any drift found between docs and code.',
              '',
              'Trigger locally:',
              '',
              '```',
              'cd <repo>',
              'claude  # orchestrator session',
              '# then: "doc-keeper, audit mode against main"',
              '```',
              '',
              'Close this issue once the audit run completes.',
              '',
              '_Generated by `.github/workflows/docs-audit.yml`._',
            ].join('\n');
            await github.rest.issues.create({
              owner, repo, title, body,
              labels: ['doc-stale', 'audit'],
            });
