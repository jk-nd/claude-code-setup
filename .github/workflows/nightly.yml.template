name: nightly

# Nightly slow-tests + extended fuzz harness.
#
# Two operational kinds:
#
#   `fuzz`       — long-tail fuzz targets that the per-PR fuzz job in
#                  ci.yml only runs for a short window. Here each runs
#                  for 10 minutes, deep enough to surface crashes the
#                  short budget misses. Crashers upload as artefacts;
#                  an issue is opened automatically with the
#                  `fuzz-crash` label.
#
#   `slow-test`  — heavyweight integration tests carrying the
#                  `e2e_nightly` build tag, moved off the per-PR e2e
#                  job. A failure opens an issue with the
#                  `nightly-slow-failure` label.
#
# Trigger model:
#   - schedule: 03:00 UTC daily.
#   - workflow_dispatch: operators can re-run on demand.
#
# This workflow runs against `origin/main` only — feature branches
# stick with the per-PR jobs from ci.yml. We don't want every push
# paying the 10-minute fuzz tax or the 15-minute slow-suite tax.
#
# Before the first run, ensure both labels exist on the repository:
#   gh label create fuzz-crash \
#     --description "Crash discovered by nightly fuzz" --color B60205
#   gh label create nightly-slow-failure \
#     --description "Failure discovered by nightly slow-tests" --color B60205
#
# Customise this workflow at template-instantiation time:
#   - Replace the `matrix.include` entries with the fuzz targets and
#     slow-test packages your project ships. The Go-flavoured shape
#     below is a starting point; adapt `package`, `target`, `tags`,
#     and `duration` per row.
#   - Delete this workflow entirely if your project does not have
#     fuzz targets or a slow-test build tag.

on:
  schedule:
    - cron: '0 3 * * *'
  workflow_dispatch:

permissions:
  contents: read
  issues: write

jobs:
  nightly:
    name: ${{ matrix.name }}
    runs-on: ubuntu-latest
    timeout-minutes: 30
    strategy:
      fail-fast: false
      matrix:
        # Replace these placeholder entries with your project's targets.
        # Each entry must declare `name`, `kind`, and the kind-specific
        # fields (`fuzz` needs `package`, `target`, `duration`; `slow-test`
        # needs `package`, `tags`, `timeout`).
        include:
          - { name: example-fuzz, kind: fuzz,      package: 'internal/example', target: 'FuzzParse',     duration: '10m' }
          - { name: example-slow, kind: slow-test, package: 'test/e2e/...',     tags: 'e2e,e2e_nightly', timeout: '15m' }

    steps:
      - uses: actions/checkout@v4
        with:
          ref: main

      - name: Set up Go
        uses: actions/setup-go@v5
        with:
          go-version: '1.26'
          cache: true

      # ----- fuzz path -----------------------------------------------------

      - name: Fuzz ${{ matrix.target }}
        id: fuzz
        if: matrix.kind == 'fuzz'
        run: go test -run='^$' -fuzz='^${{ matrix.target }}$' -fuzztime=${{ matrix.duration }} ./${{ matrix.package }}/...

      - name: Upload crashers
        if: matrix.kind == 'fuzz' && failure() && steps.fuzz.outcome == 'failure'
        uses: actions/upload-artifact@v4
        with:
          name: ${{ matrix.name }}-crashers
          path: ${{ matrix.package }}/testdata/fuzz/

      - name: Open fuzz crash issue
        if: matrix.kind == 'fuzz' && failure() && steps.fuzz.outcome == 'failure'
        uses: actions/github-script@v7
        with:
          github-token: ${{ secrets.GITHUB_TOKEN }}
          script: |
            const pkg = '${{ matrix.package }}';
            const target = '${{ matrix.target }}';
            const duration = '${{ matrix.duration }}';
            const matrixName = '${{ matrix.name }}';
            const runUrl = `${context.serverUrl}/${context.repo.owner}/${context.repo.repo}/actions/runs/${context.runId}`;
            await github.rest.issues.create({
              owner: context.repo.owner,
              repo: context.repo.repo,
              title: `[fuzz-crash] ${target} in ${pkg}`,
              body: [
                `Nightly fuzz run found a crasher in **${pkg}** target **${target}**.`,
                ``,
                `- Workflow run: ${runUrl}`,
                `- Package: \`${pkg}\``,
                `- Fuzz function: \`${target}\``,
                `- Duration: ${duration}`,
                `- Trigger: \`${context.eventName}\``,
                ``,
                `## Reproducer`,
                ``,
                `Download the crasher artefact \`${matrixName}-crashers\` from the workflow`,
                `run above. The crashing input lands in \`${pkg}/testdata/fuzz/${target}/\`.`,
                ``,
                `## Local repro`,
                ``,
                '```',
                `go test -run='^$' -fuzz='^${target}$' -fuzztime=${duration} ./${pkg}/...`,
                '```',
              ].join('\n'),
              labels: ['fuzz-crash', 'bug'],
            });

      # ----- slow-test path -----------------------------------------------

      - name: Slow e2e suite
        id: slow_test
        if: matrix.kind == 'slow-test'
        run: go test -tags=${{ matrix.tags }} -race -count=1 -timeout=${{ matrix.timeout }} ./${{ matrix.package }}

      - name: Open slow-test failure issue
        if: matrix.kind == 'slow-test' && failure() && steps.slow_test.outcome == 'failure'
        uses: actions/github-script@v7
        with:
          github-token: ${{ secrets.GITHUB_TOKEN }}
          script: |
            const tags = '${{ matrix.tags }}';
            const pkg = '${{ matrix.package }}';
            const timeout = '${{ matrix.timeout }}';
            const runUrl = `${context.serverUrl}/${context.repo.owner}/${context.repo.repo}/actions/runs/${context.runId}`;
            await github.rest.issues.create({
              owner: context.repo.owner,
              repo: context.repo.repo,
              title: `[nightly-slow] e2e_nightly suite failed`,
              body: [
                `Nightly slow-test run reported a failure in the \`e2e_nightly\` suite.`,
                ``,
                `- Workflow run: ${runUrl}`,
                `- Tag set: \`${tags}\``,
                `- Trigger: \`${context.eventName}\``,
                ``,
                `## Local repro`,
                ``,
                '```',
                `go test -tags=${tags} -race -count=1 -timeout=${timeout} ./${pkg}`,
                '```',
              ].join('\n'),
              labels: ['nightly-slow-failure', 'bug'],
            });
